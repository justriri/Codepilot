# --- Model provider selection ---
# Which provider powers the agent. Options: anthropic, deepseek, openai, local
DEFAULT_MODEL=deepseek

# --- DeepSeek ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-pro

# --- Optional providers (leave empty) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Local model (optional) ---
LOCAL_MODEL_NAME=
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1

# --- Agent core ---
WORKSPACE_ROOT=./workspace
MAX_ITERATIONS=35
COMMAND_TIMEOUT_S=30

# --- Sandbox (E2B cloud) ---
# Get a key at https://e2b.dev/docs — required for create_sandbox to work.
E2B_API_KEY=your_e2b_api_key_here
SANDBOX_TTL_S=600

# Optional: pre-built E2B template with Playwright at /opt/agent-tools
# Build with: ./e2b/build-template.sh — see docs/E2B_TEMPLATE.md
E2B_TEMPLATE_ID=

# Browser for verification: auto | all | firefox | chromium | webkit
# auto picks firefox on E2B, chromium on custom templates; all runs every engine
BROWSER_ENGINE=auto

# --- Debugging loop ---
MAX_REPAIR_ATTEMPTS=3
DEBUG_AGENT_MAX_ITERATIONS=6
